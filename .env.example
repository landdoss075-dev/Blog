# Скопируй этот файл в .env и заполни своими ключами (для локальных тестов).
# В GitHub Actions эти же значения хранятся в Settings -> Secrets and variables -> Actions.

# --- Провайдер генерации текста ---
# groq   — бесплатно, модель Llama 3.3 70b (Meta)
# openai — платно, модели GPT-4o / GPT-5 (сильнее в русском языке)
PROVIDER=groq

# --- Groq (нужен, если PROVIDER=groq) ---
# Ключ: https://console.groq.com -> API Keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI (нужен, если PROVIDER=openai) ---
# Ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Картинки (опционально, без него публикуется без фото) ---
# Access Key Unsplash: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# --- Telegram (опционально: если пусто — публикация в Telegram пропускается) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_CHANNEL_URL=

# --- Telegram/сайт для ниши «Дачные будни» ---
# Эти значения используются workflow Daily Dacha Post и запуском:
# node scripts/generate_and_post.js --niche=dacha
DACHA_SITE_URL=https://dachnye-budni.ru
DACHA_TELEGRAM_BOT_TOKEN=
DACHA_TELEGRAM_CHANNEL_ID=@dachniye_budni
DACHA_TELEGRAM_CHANNEL_URL=https://t.me/dachniye_budni

# --- Публикация на сайт atmoapp.ru (если пусто — шаг пропускается) ---
# Тот же секрет нужно прописать в backend/.env как INGEST_SECRET и передеплоить бэкенд.
ATMO_API_URL=https://atmoapp.ru/api
ATMO_INGEST_SECRET=

# --- Сайт GitHub Pages (источник RSS для Яндекс Дзена; если пусто — шаг пропускается) ---
# У Дзена нет API публикации — статьи импортируются из RSS-ленты нашего сайта.
# Базовый URL, напр. https://USERNAME.github.io/REPO  (без слэша в конце)
SITE_URL=
SITE_TITLE=ИИ-инструменты: блог
SITE_DESCRIPTION=Практические статьи про ИИ-инструменты и нейросети.
SITE_AUTHOR=Редакция

# DRY_RUN=1 — сгенерировать статью в out/, ничего не публикуя
DRY_RUN=
